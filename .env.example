# ============================================================
# MOVIA BACKEND — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# ── Base de données PostgreSQL (Render fournit cette URL) ──
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ── JWT Configuration ─────────────────────────────────────
JWT_SECRET="votre_secret_jwt_tres_long_et_securise_min_32_chars"
JWT_EXPIRATION="7d"

# ── Application ───────────────────────────────────────────
NODE_ENV="production"
PORT=8080

# ── CORS ──────────────────────────────────────────────────
# Liste des origines autorisées (séparées par virgule)
# Laisser vide pour accepter toutes les origines en dev
ALLOWED_ORIGINS=""

# ── Cloudinary (Upload avatars/photos) ───────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Email (optionnel — pour vérification email) ──────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ── API Interne (Scanner QR contrôleur) ──────────────────
INTERNAL_API_SECRET="secret_interne_securise"
